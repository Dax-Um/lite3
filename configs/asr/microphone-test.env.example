# Copy these options into the command line or a systemd unit later.
# The service deliberately publishes no MQTT, ROS, or motion commands.
ASR_ASSET_ROOT=assets/asr
# Place libonnxruntime.so (and matching versioned file, if any) in assets/asr/lib/.
ASR_PIPEWIRE_TARGET=alsa_input.usb-INNOTRIK_USB_PnP_Sound_Device_202407040001-00.analog-stereo
ASR_LANGUAGE=en
ASR_VAD_ONSET_RMS=50
ASR_VAD_RELEASE_RMS=20
